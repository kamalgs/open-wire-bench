# single-node.env — saturate a single open-wire node with realistic load.
# Multiple processes on one machine, each role as separate shards.
# Usage: ./run.sh local scenarios/single-node.env
#
# Topology: everything → localhost:4224 (one open-wire node, --binary-port 4224)
#
# Expected aggregate load:
#   ~2200 market msg/s published (500 symbols, Zipf rate profile)
#   ~3000 total subscriptions active (200 users × 20 visible + private feeds)
#   ~200 orders/s, ~100 trades/s

URL=localhost:4224
USERS=200
ALGO_USERS=20
SYMBOLS=500
VISIBLE=20
ALPHA=1.0
SCREENS=
SCROLL_INTERVAL=10s
SCROLL_COUNT=5
TICK_CLASSES=
ALGO_TIERS=
SIZE=128
DURATION=120s

# 4 user shards (50 users each), 2 market shards, 1 account shard.
USER_SHARDS=4
MARKET_SHARDS=2
ACCOUNT_SHARDS=1
