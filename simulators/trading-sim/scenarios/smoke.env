# smoke.env — quick local smoke test
# All roles in one process, small counts, 30s duration.
# Usage: ./run.sh local scenarios/smoke.env
#
# Expected: ~5K market msg/s, ~150 orders/s, ~75 trades/s
#           1-2ms p50 latency on localhost

URL=localhost:4224
USERS=50
ALGO_USERS=5
SYMBOLS=200
VISIBLE=15
ALPHA=1.0
SCROLL_INTERVAL=10s
SCROLL_COUNT=3
SIZE=128
DURATION=30s

# Single process, all roles.
USER_SHARDS=1
MARKET_SHARDS=1
ACCOUNT_SHARDS=1

# Run all actors in one process for smoke test.
BINARY=bin/trading-sim
