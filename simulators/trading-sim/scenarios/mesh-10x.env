# mesh-10x.env — 10× scale on a mesh cluster.
# Run publisher and user shards across multiple machines.
# Usage: ./run.sh ssh scenarios/mesh-10x.env hub-0 hub-1 sim-0 sim-1
#
# Topology:
#   user shards     → gateway or hub NLB:4224 (binary clients)
#   market shards   → hub NLB:4224 (publishers)
#   account shards  → hub NLB:4224 (publishers)
#
# Override URL per role by running separate invocations of run.sh, or set
# separate URLs via a custom launch script.
#
# Expected aggregate load:
#   ~22000 market msg/s (5000 symbols, Zipf distribution)
#   ~30000 active subscriptions (2000 users × 20 visible + private feeds)
#   ~2000 orders/s, ~1000 trades/s

URL=localhost:4224          # override with NLB DNS in practice
USERS=2000
ALGO_USERS=200
SYMBOLS=5000
VISIBLE=20
ALPHA=1.0
SCREENS=
SCROLL_INTERVAL=10s
SCROLL_COUNT=5
TICK_CLASSES=hot:2%@30,warm:8%@8,cool:40%@1,cold:50%@0.1
ALGO_TIERS=hft:1%@2.0/1.0,mm:10%@0.5/0.3,retail:89%@0.05/0.02
SIZE=128
DURATION=180s

# 20 user shards (100 users each), 4 market shards, 2 account shards.
# Distribute across sim machines via: ./run.sh ssh ... sim-0 sim-1 sim-2 sim-3
USER_SHARDS=20
MARKET_SHARDS=4
ACCOUNT_SHARDS=2

REMOTE_BINARY=/opt/bench/bin/trading-sim
