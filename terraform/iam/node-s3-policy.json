{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "ResultsBucket",
      "Effect": "Allow",
      "Action": [
        "s3:PutObject",
        "s3:GetObject",
        "s3:ListBucket"
      ],
      "Resource": [
        "arn:aws:s3:::open-wire-bench-results",
        "arn:aws:s3:::open-wire-bench-results/*"
      ]
    }
  ]
}
