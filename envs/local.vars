# Local environment — Nomad dev mode, single node

# Broker Docker images
open_wire_image   = "ghcr.io/kamalgs/open-wire:latest"
nats_server_image = "nats:latest"

# Workload parameters
broker_count = 1
workers      = 1
symbols      = 50
pub_rate     = 2000
msg_size     = 128
sub_count    = 2
duration     = "3m"
