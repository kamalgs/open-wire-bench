# AWS environment — 3 broker + 2 pub + 2 sub nodes (c5n.2xlarge)
broker_count    = 3
workers         = 3
symbols         = 1000
pub_rate        = 200000
msg_size        = 128
sub_count       = 4
duration        = "10m"
registry_host   = "registry.service.consul:5000"
open_wire_tag   = "latest"
nats_server_tag = "latest"
